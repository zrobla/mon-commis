# MON COMMIS — variables d'environnement (copier en .env, NE PAS committer .env)
# Générer une clé : python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=change-me-en-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Origines autorisées à POSTer vers l'API (la vitrine). En prod : https://moncommis.ci
CORS_ALLOWED_ORIGINS=http://localhost:8765,http://127.0.0.1:8765

# Production uniquement (DEBUG=False)
CSRF_TRUSTED_ORIGINS=https://moncommis.ci
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
